/* 首页样式 */
.home-container {
  min-height: 100vh;
  padding: 30rpx;
}

/* 大标题 */
.hero-section {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-between;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 6rpx;
}

/* 组信息卡片 */
.group-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.group-card:active {
  opacity: 0.8;
}

.group-left {
  flex: 1;
}

.group-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.group-num {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
  margin: 6rpx 0;
}

.group-range {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.group-right {
  text-align: center;
  margin-left: 20rpx;
}

.group-progress-text {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.group-progress-bar {
  width: 100rpx;
  height: 8rpx;
  background: var(--border);
  border-radius: 4rpx;
  overflow: hidden;
  margin: 8rpx auto;
}

.group-progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.group-change {
  font-size: 22rpx;
  color: var(--text-light);
}

/* 开始听写 */
.action-section {
  margin-bottom: 30rpx;
}

.start-card {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  border-radius: 20rpx;
  padding: 36rpx;
  text-align: center;
  box-shadow: 0 4px 16px rgba(74, 144, 217, 0.3);
}

.start-card:active {
  opacity: 0.9;
}

.start-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 12rpx;
}

.start-text {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.start-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

/* 设置 */
.settings-section {
  margin-bottom: 30rpx;
}

.setting-group {
  margin-bottom: 24rpx;
}

.setting-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.option-row {
  display: flex;
  gap: 16rpx;
}

.option-item {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 2rpx solid var(--border);
}

.option-item.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

/* 分类标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* 字母索引网格 */
.alphabet-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.alpha-item {
  width: calc(12.5% - 11rpx);
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 16rpx 0;
  text-align: center;
  box-shadow: var(--shadow);
  box-sizing: border-box;
}

.alpha-item:active {
  opacity: 0.7;
}

.alpha-letter {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.alpha-count {
  display: block;
  font-size: 20rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}
