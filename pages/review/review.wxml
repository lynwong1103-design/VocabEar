<!-- 复习页 -->
<view class="review-container">
  <view class="review-header">
    <text class="review-title">错词复习</text>
    <text class="review-count">待复习 {{wrongCount}} 词</text>
  </view>

  <!-- 卡片区域 -->
  <view class="card-area" wx:if="{{wrongCount > 0}}">
    <view class="flash-card {{flipped ? 'flipped' : ''}}" bindtap="onFlip">
      <view class="card-inner">
        <!-- 正面：中文 -->
        <view class="card-front">
          <view class="sound-btn-sm" catchtap="onPlaySound">
            <text>🔊</text>
          </view>
          <text class="card-zh">{{currentWord.zh}}</text>
          <text class="card-tip">点击翻转查看答案</text>
        </view>
        <!-- 反面：英文 -->
        <view class="card-back">
          <text class="card-en">{{currentWord.en}}</text>
          <text class="card-phonetic">{{currentWord.phonetic}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="card-actions">
      <button class="btn-secondary" bindtap="onStillWrong">还需练习 🔄</button>
      <button class="btn-primary" bindtap="onMastered">已掌握 ✅</button>
    </view>

    <!-- 进度指示 -->
    <view class="card-nav">
      <text class="nav-dot {{index === currentIdx ? 'active' : ''}}" 
        wx:for="{{wrongCount}}" wx:key="index"></text>
    </view>
  </view>

  <!-- 无错词 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">🎉</text>
    <text class="empty-text">太棒了！暂时没有需要复习的错词</text>
  </view>
</view>
